EXP_REDIS_PASSWORD=development-only-redis-password
EXP_RABBITMQ_USERNAME=example
EXP_RABBITMQ_PASSWORD=development-only-rabbitmq-password
EXP_SQLSERVER_SA_PASSWORD=Development-only-Sql1!

# Export these application-facing values in your shell before running examples.
EXP_REDIS_CONNECTION_STRING=localhost:6379,password=development-only-redis-password,ssl=False,defaultDatabase=0
EXP_MONGODB_CONNECTION_STRING=mongodb://localhost:27017/ExpWeatherLogs
EXP_SQLSERVER_CONNECTION_STRING=Server=localhost,1433;Database=ExpWeatherLogs;User Id=sa;Password=Development-only-Sql1!;TrustServerCertificate=true

# Azure Key Vault is not emulated by Compose. Fill these only in your local .env.
EXP_AZURE_KEY_VAULT_URL=https://your-development-vault.vault.azure.net/
EXP_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
EXP_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
EXP_AZURE_CLIENT_SECRET=replace-locally
