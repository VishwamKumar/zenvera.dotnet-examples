{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:6203",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "Kestrel__Endpoints__Https__Certificate__Password": "development-only-certificate-password",
        "Kestrel__Endpoints__Https__Certificate__Path": "replace-with-local-server-certificate.pfx"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:8203;http://localhost:6203",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "Kestrel__Endpoints__Https__Certificate__Password": "development-only-certificate-password",
        "Kestrel__Endpoints__Https__Certificate__Path": "replace-with-local-server-certificate.pfx"
      }
    }
  }
}
