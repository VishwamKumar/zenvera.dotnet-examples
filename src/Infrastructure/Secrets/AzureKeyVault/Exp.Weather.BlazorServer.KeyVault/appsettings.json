{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "KeyVaultSettings": {
    "Provider": "Azure", //  Azure for now, later - AWS | GCP | HashiCorp etc.    
    "CacheExpiryMinutes": 30, // Duration for which the secrets will be cached in memory,  
    "UseSlidingExpiration": true, // Set to true if you want to use sliding expiration for cached secrets"

    "Providers": {
      "Azure": {
        "KeyVaultUrl": "ENV:EXP_AZURE_KEY_VAULT_URL",
        "TenantId": "ENV:EXP_AZURE_TENANT_ID",
        "ClientId": "ENV:EXP_AZURE_CLIENT_ID",
        "ClientSecret": "ENV:EXP_AZURE_CLIENT_SECRET"
      }
    }
  },

  "CacheSettings": { // Optional caching settings if UseCaching is true
    "Provider": "Redis", // Options: Redis, InMemory    
    "DefaultPolicy": {
      "Expiration": "00:30:00", // Absolute expiration
      "SlidingExpiration": "00:15:00" // Sliding expiration (optional)      
    },
    "Providers": {
      "Redis": {
        "ConnectionString": "ENV:EXP_REDIS_CONNECTION_STRING",
        "InstanceName": "ExpWeatherCache"
      }
    }
  },

  "FeatureFlags": { //Optional feature flags, speically for turning off
    "UseKeyVault": true, //default is true, set to false to disable Azure Key Vault integration
    "UseCaching": false // true = Redis, false = InMemory
  } 
}
